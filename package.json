{
  "name": "farmsense",
  "version": "1.0.0",
  "description": "FarmSense \u2014 AI Farm Monitor and Crop Management",
  "main": "electron/main.js",
  "author": "Christopher Cadger <cadger808@codeberg.org>",
  "license": "UNLICENSED",
  "scripts": {
    "electron": "electron .",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "electron-builder --linux",
    "electron:dist": "electron-builder --linux AppImage rpm",
    "cap:sync": "npx cap copy && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/camera": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.2",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.cadger808.farmsense",
    "productName": "FarmSense",
    "copyright": "Copyright \u00a9 2025 Christopher Cadger",
    "directories": {
      "output": "dist-electron",
      "buildResources": "icons"
    },
    "files": [
      "index.html",
      "api-client.js",
      "magic-link.js",
      "manifest.json",
      "sw.js",
      "avatar-widget.js",
      "share-widget.js",
      "icons/**",
      "electron/**",
      "!node_modules/**",
      "!android/**",
      "!www/**",
      "!dist-electron/**"
    ],
    "linux": {
      "target": [
        "AppImage",
        "rpm"
      ],
      "category": "Utility",
      "icon": "icons/icon-512.png",
      "desktop": {
        "Name": "FarmSense",
        "Comment": "AI Farm Monitor",
        "Categories": "Utility;Science"
      }
    },
    "publish": {
      "provider": "generic",
      "url": "https://codeberg.org/cadger808/farmsense/releases/download/latest/"
    }
  },
  "overrides": {
    "picomatch": ">=4.0.2",
    "brace-expansion": ">=2.0.1"
  }
}
